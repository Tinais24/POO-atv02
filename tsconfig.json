{
  "compilerOptions": {
    "target": "ES6",                          /* Versão do JavaScript de saída */
    "module": "commonjs",                     /* Sistema de módulos para Node.js */
    "rootDir": "./src",                       /* Onde estão seus arquivos .ts */
    "outDir": "./dist",                       /* Onde o código compilado será salvo */
    "strict": true,                           /* Ativa todas as verificações rígidas de tipo */
    "esModuleInterop": true,                  /* Garante compatibilidade com bibliotecas antigas */
    "skipLibCheck": true,                     /* Pula checagem de tipos de bibliotecas para ser mais rápido */
    "forceConsistentCasingInFileNames": true, /* Linux diferencia maiúsculas de minúsculas */
    "resolveJsonModule": true
  },
  "include": ["src/**/*"],                    /* Inclui tudo que estiver dentro de src */
  "exclude": ["node_modules"]                 /* Ignora a pasta de bibliotecas */
}